{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Social Gyms needs the microphone so your coach can hear you during a live training session.",
        "NSCameraUsageDescription": "Social Gyms uses the front camera to read your facial expressions and show real-time presence feedback during a coaching session."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0e1424",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.barnejek.mobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0e1424",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-audio",
      "react-native-audio-api",
      [
        "expo-camera",
        {
          "cameraPermission": "Social Gyms uses the front camera to read your facial expressions and show real-time presence feedback during a coaching session.",
          "microphonePermission": "Social Gyms needs the microphone so your coach can hear you during a live training session.",
          "recordAudioAndroid": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2f727495-4221-43b9-9327-beb1dec0b508"
      }
    }
  }
}
