# ── Social Gyms Mobile ── env vars ────────────────────────────────────────────

# Gemini API key (required when the live voice engine is enabled)
EXPO_PUBLIC_GEMINI_API_KEY=your-key-here

# Set to "true" to run a fully scripted pitch demo.
# In demo mode: no WiFi needed, no Gemini quota consumed, every run is identical.
# Flip to "false" (or remove) to use the real Gemini Live engine.
EXPO_PUBLIC_DEMO_MODE=true
