# ── Social Gyms Mobile ── env vars ────────────────────────────────────────────

# Gemini API key (required for the live voice engine)
EXPO_PUBLIC_GEMINI_API_KEY=your-key-here

# Supabase project (score-conversation edge function)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Pitch-safe scripted session: plays back a pre-written transcript with fake
# emotion metrics — no WiFi, mic, camera, or Gemini quota needed.
EXPO_PUBLIC_DEMO_MODE=false
